{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun --env-file=../../.env test",
    "typecheck": "tsc --noEmit",
    "seed:local-users": "bun --env-file=../../.env run src/scripts/seed-test-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1087.0",
    "@gojo/db": "workspace:*",
    "@gojo/shared": "workspace:*",
    "@hono/zod-validator": "^0.9.0",
    "@sentry/bun": "^10.65.0",
    "better-auth": "1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "nodemailer": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^7.0.2"
  }
}
