{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "seed:local-users": "bun --env-file=../../.env run src/scripts/seed-test-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.723.0",
    "@gojo/db": "workspace:*",
    "@gojo/shared": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.63.0",
    "better-auth": "^1.2.9",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "nodemailer": "^9.0.3",
    "openid-client": "^6.8.4",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/nodemailer": "^8.0.1",
    "typescript": "^5.7.2"
  }
}
