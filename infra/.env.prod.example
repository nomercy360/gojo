# Domain (Caddy auto-HTTPS if real domain, localhost for testing)
DOMAIN=gojo.example.com

# Postgres
POSTGRES_USER=gojo
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=gojo

# JWT
JWT_SECRET=CHANGE_ME_at_least_32_characters_random_string

# LiveKit
LIVEKIT_URL=wss://gojo.example.com/lk-ws
LIVEKIT_API_KEY=gojo_prod_key
LIVEKIT_API_SECRET=CHANGE_ME_at_least_32_characters_random_string

# S3 / Minio
S3_ACCESS_KEY=gojo_s3_admin
S3_SECRET_KEY=CHANGE_ME_strong_password_here
S3_BUCKET=gojo
S3_PUBLIC_URL=https://gojo.example.com/s3

# Web
PUBLIC_API_URL=https://gojo.example.com
