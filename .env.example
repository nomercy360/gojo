# Database
DATABASE_URL=postgres://gojo:gojo@localhost:5432/gojo

# Redis
REDIS_URL=redis://localhost:6379

# S3 / Minio (local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gojo-dev

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret123456789012345678901234

# API
API_PORT=3001
API_ORIGIN=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=dev-secret-change-me-in-production-please-32chars

# SMTP (Mailpit for dev — view sent mail at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gojo.local

# Error monitoring (Sentry, free tier). Leave blank to disable — Sentry.init()
# is a documented no-op with no DSN. Separate projects recommended for api/web.
SENTRY_DSN_API=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_DSN=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# YooKassa
# Use test shop credentials locally. Configure HTTP notifications in YooKassa:
# https://<api-host>/payments/yookassa/webhook for payment.succeeded/payment.canceled.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
