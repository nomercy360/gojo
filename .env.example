# Database
DATABASE_URL=postgres://gojo:gojo@localhost:5432/gojo

# S3 / Minio (local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gojo-dev

# API
API_PORT=3001
API_ORIGIN=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=dev-secret-change-me-in-production-please-32chars

# SMTP (Mailpit for dev — view sent mail at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gojo.local

# Error monitoring (Sentry, free tier). Leave blank to disable — Sentry.init()
# is a documented no-op with no DSN. Separate projects recommended for api/web.
SENTRY_DSN_API=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_DSN=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=gojolearn_bot

# Telegram bot used for login codes, reminders, and contact conversations.
TELEGRAM_BOT_TOKEN=
# Shared secret Telegram echoes back on every webhook call (bot-initiated login).
# Generate a random string; `bun run tg:webhook` registers it with setWebhook.
TELEGRAM_WEBHOOK_SECRET=
# Browser-facing app origin used to build Telegram login links + the webhook URL.
# Leave unset locally to default to WEB_ORIGIN. For webhook testing set it to
# your ngrok URL, e.g. PUBLIC_APP_URL=https://<subdomain>.ngrok-free.app
PUBLIC_APP_URL=

# YooKassa
# Use test shop credentials locally. Configure HTTP notifications in YooKassa:
# https://<api-host>/payments/yookassa/webhook for payment.succeeded/payment.canceled.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Claude first-pass homework review (unset = AI pass skipped)
ANTHROPIC_API_KEY=

# Resend transactional email (HTTP API; prod SMTP ports are blocked on the VM)
RESEND_API_KEY=
