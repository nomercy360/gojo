{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": ["node_modules", "dist", ".next", "drizzle", "*.generated.ts"]
  },
  "overrides": [
    {
      "include": ["apps/web/src/components/landing.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useValidAnchor": "off",
            "useKeyWithClickEvents": "off"
          }
        }
      }
    }
  ]
}
