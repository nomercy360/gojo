{
  "name": "gojo",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run seed:local-users && concurrently -n web,api -c magenta,cyan \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "cd apps/web && bun run build && cd ../api && bun run build",
    "typecheck": "cd packages/db && bun run typecheck && cd ../../apps/api && bun run typecheck && cd ../web && bun run typecheck && cd ../.. && tsc -p tsconfig.e2e.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "cd packages/db && bun run generate",
    "db:migrate": "cd packages/db && bun run migrate",
    "db:studio": "cd packages/db && bun run studio",
    "seed:local-users": "cd apps/api && bun run seed:local-users",
    "test:e2e": "bun run db:migrate && playwright test",
    "test:e2e:headed": "bun run db:migrate && playwright test --headed",
    "test:e2e:ui": "bun run db:migrate && playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@gojo/db": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.12",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
